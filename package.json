{
  "name": "terminal-ds",
  "productName": "Terminal DS",
  "version": "1.0.3",
  "description": "Cross-platform split-pane GUI terminal emulator, built on xterm.js and Electron",
  "main": "main.js",
  "license": "MIT",
  "author": {
    "name": "Niklas Borneklint",
    "email": "nborneklint@gmail.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/aegisinfo/ds_terminal.git"
  },
  "scripts": {
    "start": "electron .",
    "postinstall": "electron-rebuild -f -w node-pty",
    "build:linux": "electron-builder --linux deb",
    "build:win": "electron-builder --win nsis",
    "build:mac": "electron-builder --mac dmg"
  },
  "dependencies": {
    "node-pty": "^1.0.0",
    "xterm": "^5.3.0",
    "xterm-addon-fit": "^0.8.0",
    "xterm-addon-web-links": "^0.9.0",
    "xterm-addon-search": "^0.13.0"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "@electron/rebuild": "^3.6.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "org.aegiscloud.terminalds",
    "productName": "Terminal DS",
    "executableName": "terminal-ds",
    "asar": true,
    "asarUnpack": [
      "node_modules/node-pty/**"
    ],
    "files": [
      "**/*",
      "!node_modules/electron-builder/**"
    ],
    "linux": {
      "target": ["deb"],
      "category": "System",
      "synopsis": "Cross-platform split-pane GUI terminal emulator"
    },
    "deb": {
      "compression": "gz"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "shortcutName": "Terminal DS",
      "menuCategory": "Terminal DS",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "mac": {
      "target": "dmg",
      "category": "public.app-category.developer-tools"
    }
  }
}
